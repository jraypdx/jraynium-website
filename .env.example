PORT=3000

# reCAPTCHA keys (from https://www.google.com/recaptcha/admin)
RECAPTCHA_V3_SECRET_KEY=your_recaptcha_v3_secret_key
RECAPTCHA_SECRET_KEY=your_recaptcha_v2_secret_key

# Email config for contact form + file upload notifications (optional)
# For Gmail, use an App Password (not your regular password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=your@gmail.com
